<!-- 기관 헤더 -->
<div class="inst-detail-header">
  <div class="inst-mark" style="background: {{ institution.color }}22; border: 1px solid {{ institution.color }}55; color: {{ institution.color }};">
    {{ institution.mark }}
  </div>
  <div class="inst-info">
    <h1 class="inst-name">{{ institution.name }}</h1>
    <a href="{{ institution.list_url }}" target="_blank" rel="noopener" class="inst-link">기관 웹사이트 →</a>
  </div>
</div>

<!-- 보고서 목록 -->
<div class="inst-reports">
  <div id="reportsList"></div>
</div>

<!-- 페이지네이션 -->
<div id="pagination"></div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const instCode = '{{ institution.code }}';
  const pageSize = 10;

  const reportsData = [
    {% for report in collections.reports | byInstitution(institution.code, 999) %}{
      url: '{{ report.url | url }}',
      title: '{{ report.data.title }}',
      lead_researcher: '{{ report.data.lead_researcher or "" }}',
      lead_affiliation: '{{ report.data.lead_affiliation or "" }}',
      date: '{{ report.data.date | ymd }}'
    }{{ "," if not loop.last }}{% endfor %}
  ];

  function formatAuthor(report) {
    if (!report.lead_researcher) return '-';
    if (!report.lead_affiliation) return report.lead_researcher;
    return `${report.lead_researcher} (${report.lead_affiliation})`;
  }

  let currentPage = 1;
  const totalPages = Math.ceil(reportsData.length / pageSize);

  function renderPage(page) {
    const start = (page - 1) * pageSize;
    const end = start + pageSize;
    const pageReports = reportsData.slice(start, end);

    const reportsList = document.getElementById('reportsList');
    reportsList.innerHTML = `
      <table class="report-list-detail">
        <tbody>
          ${pageReports.map(report => `
            <tr>
              <td class="report-title-cell">
                <a href="${report.url}">${report.title}</a>
              </td>
              <td class="report-author-cell">${formatAuthor(report)}</td>
              <td class="report-date-cell">${report.date}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;

    // 페이지네이션
    if (totalPages > 1) {
      const paginationDiv = document.getElementById('pagination');
      let paginationHTML = '<div class="pagination">';

      if (page > 1) {
        paginationHTML += `<button onclick="renderPage(${page - 1})" class="pagination-link">← 이전</button>`;
      }

      paginationHTML += '<div class="pagination-numbers">';
      for (let i = 1; i <= totalPages; i++) {
        if (i === page) {
          paginationHTML += `<span class="pagination-current">${i}</span>`;
        } else {
          paginationHTML += `<button onclick="renderPage(${i})" class="pagination-number">${i}</button>`;
        }
      }
      paginationHTML += '</div>';

      if (page < totalPages) {
        paginationHTML += `<button onclick="renderPage(${page + 1})" class="pagination-link">다음 →</button>`;
      }

      paginationHTML += '</div>';
      paginationDiv.innerHTML = paginationHTML;
    }

    currentPage = page;
    window.scrollTo(0, 0);
  }

  window.renderPage = renderPage;
  renderPage(1);
});
</script>
