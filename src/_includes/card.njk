<section class="inst-card" data-code="{{ institution.code }}">
  <div class="inst-card-header">
    <a href="{{ institution.list_url }}" target="_blank" rel="noopener" class="inst-card-link">
      <div class="inst-mark" style="background: {{ institution.color }}22; border: 1px solid {{ institution.color }}55; color: {{ institution.color }};">{{ institution.mark }}</div>
      <div class="inst-name">{{ institution.name }}</div>
    </a>
    {% if not institution.link_only %}<div class="inst-count">{{ instReports.length }}건</div>{% endif %}
  </div>

  {% if institution.link_only %}
    <a class="btn-link" href="{{ institution.list_url }}" target="_blank" rel="noopener">사이트 바로가기</a>
  {% else %}
    <ul class="report-list">
      {% for report in instReports | limit(5) %}
      <li>
        <a href="{{ report.url | url }}">
          <span class="report-title">{{ report.data.title }}</span>
          <span class="report-date">{{ report.data.date | ymd }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
    {% if instReports.length > 5 %}<a class="more-btn" href="{{ institution.list_url }}" target="_blank" rel="noopener">더보기 →</a>{% endif %}
  {% endif %}
</section>
