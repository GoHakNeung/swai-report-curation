<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}SWAI 아카이브</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { background: #0b0c0e; }
    body { background: #0b0c0e; color: #e8e8ea; font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Malgun Gothic', sans-serif; line-height: 1.6; }
    a { color: #8b7cf6; text-decoration: none; }
    a:hover { color: #a89bff; }
    ::selection { background: #6C5CE7; color: #fff; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: #2a2c31; border-radius: 4px; }

    header {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 40px;
      background: rgba(11, 12, 14, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #1e1f24;
    }

    .header-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      color: inherit;
      transition: opacity 0.2s;
    }

    .header-brand:hover {
      color: inherit;
      opacity: 0.7;
    }

    .header-logo {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, #6C5CE7, #4834d4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 14px;
      color: #fff;
    }

    .header-title {
      font-weight: 700;
      font-size: 16px;
      letter-spacing: -0.02em;
    }

    .header-subtitle {
      font-size: 11px;
      color: #8a8d96;
      font-family: 'IBM Plex Mono', monospace;
    }

    .header-search {
      position: relative;
      width: 340px;
    }

    .header-search input {
      width: 100%;
      padding: 10px 14px 10px 38px;
      border-radius: 10px;
      border: 1px solid #2a2c31;
      background: #17181c;
      color: #e8e8ea;
      font-size: 14px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }

    .header-search input:focus {
      border-color: #6C5CE7;
    }

    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #6a6d76;
      font-size: 15px;
    }

    main {
      min-height: calc(100vh - 200px);
    }

    footer {
      background: #0b0c0e;
      color: #5a5d66;
      padding: 40px;
      text-align: center;
      font-size: 13px;
      border-top: 1px solid #1e1f24;
    }

    .grid {
      max-width: 1240px;
      margin: 0 auto;
      padding: 32px 40px 80px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 20px;
    }

    @media (max-width: 768px) {
      .grid {
        grid-template-columns: 1fr;
        padding: 32px 20px 80px;
      }
      header {
        flex-direction: column;
        padding: 16px 20px;
        align-items: flex-start;
        gap: 16px;
      }
      .header-search {
        width: 100%;
      }
    }

    .inst-card {
      border: 1px solid #1e1f24;
      border-radius: 16px;
      background: #131418;
      padding: 24px;
      display: flex;
      flex-direction: column;
      transition: border-color 0.2s;
      min-height: 280px;
      min-width: 0;
    }

    .inst-card:hover {
      border-color: #6C5CE7;
    }

    .group {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 20px;
      border: 2px solid #1e1f24;
      border-radius: 12px;
      padding: 16px;
    }

    @media (max-width: 768px) {
      .group {
        grid-template-columns: 1fr;
        padding: 12px;
      }
    }

    .inst-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .inst-card-link {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: inherit;
      transition: opacity 0.2s;
    }

    .inst-card-link:hover {
      opacity: 0.7;
    }

    .inst-card-info {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .inst-mark {
      flex: 0 0 auto;
      width: 34px;
      height: 34px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: 700;
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: -0.03em;
    }

    .inst-name {
      font-size: 15px;
      font-weight: 600;
      color: #e8e8ea;
    }

    .inst-count {
      font-size: 11px;
      color: #5a5d66;
      font-family: 'IBM Plex Mono', monospace;
    }

    .report-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin-bottom: 14px;
    }

    .report-list li {
      border-bottom: 1px solid #1c1d22;
      padding-left: 12px;
    }

    .report-list li:last-child {
      border-bottom: none;
    }

    .report-list a {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 9px 0;
      color: #c9cad0;
      font-size: 14px;
      transition: color 0.2s;
    }

    .report-list a:hover {
      color: #a89bff;
    }

    .report-title {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .report-date {
      flex: 0 0 auto;
      font-size: 11px;
      color: #5a5d66;
      font-family: 'IBM Plex Mono', monospace;
    }

    .more-btn {
      align-self: flex-start;
      font-size: 12px;
      color: #8a8d96;
      border: 1px solid #2a2c31;
      padding: 6px 12px;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .more-btn:hover {
      color: #e8e8ea;
      border-color: #6C5CE7;
    }

    .btn-link {
      align-self: flex-start;
      font-size: 12px;
      color: #e8e8ea;
      border: 1px solid #2a2c31;
      padding: 6px 12px;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .btn-link:hover {
      color: #a89bff;
      border-color: #6C5CE7;
    }

    .search-results {
      max-width: 920px;
      margin: 0 auto;
      padding: 40px;
    }

    .search-result-label {
      font-size: 13px;
      color: #8a8d96;
      margin-bottom: 16px;
      font-family: 'IBM Plex Mono', monospace;
    }

    .search-result-item {
      display: flex;
      align-items: baseline;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid #1e1f24;
      transition: background 0.2s;
    }

    .search-result-item:hover {
      background: rgba(11, 12, 14, 0.8);
    }

    .search-result-item a {
      display: flex;
      align-items: baseline;
      gap: 16px;
      flex: 1;
      color: inherit;
    }

    .search-result-inst {
      flex: 0 0 150px;
      font-size: 12px;
      color: #8a8d96;
      font-family: 'IBM Plex Mono', monospace;
    }

    .search-result-title {
      flex: 1;
      font-size: 15px;
      color: #e8e8ea;
      font-weight: 500;
      transition: color 0.2s;
    }

    .search-result-item a:hover .search-result-title {
      color: #a89bff;
    }

    .search-result-date {
      flex: 0 0 auto;
      font-size: 12px;
      color: #5a5d66;
      font-family: 'IBM Plex Mono', monospace;
    }

    .no-results {
      padding: 60px 0;
      text-align: center;
      color: #5a5d66;
      font-size: 14px;
    }

    article.report {
      max-width: 920px;
      margin: 0 auto;
      padding: 40px;
      background: #131418;
      border-radius: 12px;
      border: 1px solid #1e1f24;
    }

    article.report h1 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      line-height: 1.3;
      color: #e8e8ea;
    }

    .report-meta {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem 1rem;
      padding: 1.5rem;
      background: #0b0c0e;
      border-radius: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.875rem;
      border-left: 4px solid #6C5CE7;
    }

    .report-meta dt {
      font-weight: 600;
      color: #8a8d96;
    }

    .report-meta dd {
      color: #e8e8ea;
      margin: 0;
    }

    .report-body {
      font-size: 0.95rem;
      line-height: 1.8;
      color: #c9cad0;
      margin-bottom: 2rem;
    }

    .report-body h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 1.5rem 0 0.75rem;
      color: #8b7cf6;
      letter-spacing: 0.02em;
    }

    .report-body h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin: 1.25rem 0 0.5rem;
      color: #d9d9de;
    }

    .report-body ul, .report-body ol {
      margin: 0.75rem 0 0.75rem 1.5rem;
    }

    .report-body li {
      margin-bottom: 0.5rem;
    }

    .table-of-contents {
      background: #0b0c0e;
      border: 1px solid #1e1f24;
      border-radius: 0.5rem;
      padding: 1rem;
      margin: 1.5rem 0;
      font-size: 0.875rem;
    }

    .table-of-contents h3 {
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
      color: #e8e8ea;
    }

    .table-of-contents ul {
      list-style: none;
      margin: 0;
      color: #c9cad0;
    }

    .table-of-contents li {
      padding: 0.25rem 0;
    }

    .report-links {
      padding-top: 1.5rem;
      border-top: 1px solid #1e1f24;
      font-size: 0.875rem;
    }

    .report-links a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: #6C5CE7;
      color: #ffffff;
      border-radius: 0.375rem;
      margin-right: 0.5rem;
      margin-bottom: 0.5rem;
      transition: background 0.2s;
    }

    .report-links a:hover {
      background: #5946c9;
      text-decoration: none;
    }

    .report-inst-link {
      transition: opacity 0.2s;
    }

    .report-inst-link:hover {
      opacity: 0.7;
    }

    .breadcrumb {
      font-size: 0.875rem;
      color: #8a8d96;
      margin-bottom: 1.5rem;
    }

    .breadcrumb a {
      color: #8b7cf6;
    }

    /* 기관 상세 페이지 헤더 */
    .inst-detail-header {
      max-width: 920px;
      margin: 0 auto 40px;
      padding: 40px;
      display: flex;
      align-items: center;
      gap: 20px;
      background: #131418;
      border-radius: 12px;
      border: 1px solid #1e1f24;
    }

    .inst-detail-header .inst-mark {
      width: 60px;
      height: 60px;
      font-size: 12px;
      flex-shrink: 0;
    }

    .inst-info {
      flex: 1;
    }

    .inst-detail-header .inst-name {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: #e8e8ea;
      font-family: Pretendard, -apple-system, BlinkMacSystemFont, 'Malgun Gothic', sans-serif;
    }

    .inst-link {
      font-size: 13px;
      color: #8a8d96;
      border: 1px solid #2a2c31;
      padding: 6px 12px;
      border-radius: 8px;
      display: inline-block;
      transition: all 0.2s;
    }

    .inst-link:hover {
      color: #a89bff;
      border-color: #6C5CE7;
    }

    /* 기관 보고서 목록 */
    .inst-reports {
      max-width: 920px;
      margin: 0 auto 40px;
    }

    .report-list-detail {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    .report-list-detail tbody tr {
      border-bottom: 1px solid #1e1f24;
      transition: background 0.2s;
    }

    .report-list-detail tbody tr:hover {
      background: rgba(139, 124, 246, 0.08);
    }

    .report-list-detail tbody tr:last-child {
      border-bottom: none;
    }

    .report-list-detail td {
      padding: 12px 16px;
      vertical-align: middle;
    }

    .report-title-cell {
      flex: 1;
      font-family: Pretendard, -apple-system, BlinkMacSystemFont, 'Malgun Gothic', sans-serif;
      font-size: 14px;
      font-weight: 500;
    }

    .report-title-cell a {
      color: #c9cad0;
      transition: color 0.2s;
    }

    .report-title-cell a:hover {
      color: #a89bff;
    }

    .report-author-cell {
      width: 200px;
      color: #8a8d96;
      font-size: 12px;
      text-align: center;
    }

    .report-date-cell {
      width: 104px;
      color: #5a5d66;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      text-align: right;
      white-space: nowrap;
    }

    /* 페이지네이션 */
    .pagination {
      max-width: 920px;
      margin: 0 auto 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
    }

    .pagination-numbers {
      display: flex;
      gap: 8px;
    }

    .pagination-link {
      font-size: 13px;
      color: #8a8d96;
      border: 1px solid #2a2c31;
      padding: 8px 12px;
      border-radius: 8px;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .pagination-link:hover {
      color: #a89bff;
      border-color: #6C5CE7;
    }

    .pagination-number {
      font-size: 13px;
      color: #8a8d96;
      border: 1px solid #2a2c31;
      padding: 8px 10px;
      border-radius: 6px;
      transition: all 0.2s;
      min-width: 36px;
      text-align: center;
    }

    .pagination-number:hover {
      color: #a89bff;
      border-color: #6C5CE7;
    }

    .pagination-current {
      font-size: 13px;
      color: #e8e8ea;
      background: #6C5CE7;
      border: 1px solid #6C5CE7;
      padding: 8px 10px;
      border-radius: 6px;
      min-width: 36px;
      text-align: center;
      display: inline-block;
      font-weight: 600;
    }

    .back-link {
      max-width: 920px;
      margin: 40px auto 0;
      padding: 40px;
      text-align: center;
      font-size: 13px;
      color: #8a8d96;
    }

    .back-link a {
      color: #8b7cf6;
    }

    .back-link a:hover {
      color: #a89bff;
    }
  </style>
</head>
<body>
  <header>
    <a class="header-brand" href="{{ '/' | url }}">
      <div class="header-logo">S</div>
      <div>
        <div class="header-title">SWAI 아카이브</div>
        <div class="header-subtitle">SW·AI 교육 동향 리포트 저장소</div>
      </div>
    </a>
    {% if page.url == "/" %}<div class="header-search">
      <input type="text" id="searchInput" placeholder="제목, 요약, 키워드로 검색">
      <div class="search-icon">⌕</div>
    </div>{% endif %}
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>국내 교육·SW 연구기관의 SW·AI 관련 보고서를 수집·요약한 정적 아카이브</p>
  </footer>
</body>
</html>
