{# 보고서 상세 페이지 레이아웃. src/reports/reports.json 이 이 레이아웃을 자동 적용한다. #}
<article class="report">
  <h1>{{ title }}</h1>
  <dl class="report-meta">
    <dt>연구책임자</dt>
    <dd>{{ lead_researcher }}</dd>
    <dt>게시일</dt>
    <dd>{{ date | ymd }}</dd>
    {% if keywords and keywords.length %}
    <dt>키워드</dt>
    <dd>{{ keywords | join(", ") }}</dd>
    {% endif %}
  </dl>

  <div class="report-body">
    {{ content | safe }}
  </div>

  <p class="report-links">
    <a href="{{ source_url }}" target="_blank" rel="noopener">원문 보기</a>
    {% if pdf_url %} · <a href="{{ pdf_url }}" target="_blank" rel="noopener">PDF</a>{% endif %}
  </p>
</article>
