---
layout: base.njk
---
<div id="archiveContainer">
  <div class="grid" id="institutionGrid">
    {% for institution in institutions | byOrder %}
      {% if loop.index == 1 %}<div class="group">{% endif %}
      {% if loop.index == 7 %}</div><div class="group">{% endif %}
      {% if loop.index == 9 %}</div><div class="group">{% endif %}

      {% set instReports = collections.reports | byInstitution(institution.code) %}
      {% include "card.njk" %}

      {% if loop.last %}</div>{% endif %}
    {% endfor %}
  </div>
  <div class="search-results" id="searchResults" style="display: none;">
    <div style="max-width: 920px; margin: 0 auto; padding: 40px;">
      <div class="search-result-label" id="resultLabel"></div>
      <div id="resultsList"></div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchInput');
  if (!searchInput) return;

  const grid = document.getElementById('institutionGrid');
  const resultsContainer = document.getElementById('searchResults');
  const resultLabel = document.getElementById('resultLabel');
  const resultsList = document.getElementById('resultsList');

  const externalInsts = [{% for inst in institutions %}{% if inst.title_external %}'{{ inst.code }}'{{ "," if not loop.last }}{% endif %}{% endfor %}];

  const reportsData = [
    {% for report in collections.reports %}{
      url: '{{ report.url | url }}',
      source_url: '{{ report.data.source_url }}',
      title: '{{ report.data.title }}',
      institution: '{{ report.data.institution }}',
      date: '{{ report.data.date | ymd }}',
      keywords: [{% for kw in report.data.keywords %}'{{ kw }}'{{ "," if not loop.last }}{% endfor %}],
      abstract: '{{ report.data.abstract or "" }}'
    }{{ "," if not loop.last }}{% endfor %}
  ];

  const institutionsData = [
    {% for inst in institutions %}{
      code: '{{ inst.code }}',
      name: '{{ inst.name }}'
    }{{ "," if not loop.last }}{% endfor %}
  ];

  function normalizeText(text) {
    return (text || '').toLowerCase().trim();
  }

  function performSearch(query) {
    const normalized = normalizeText(query);

    if (!normalized) {
      grid.style.display = 'grid';
      resultsContainer.style.display = 'none';
      return;
    }

    const results = reportsData.filter(report => {
      const title = normalizeText(report.title);
      const abstract = normalizeText(report.abstract);
      const keywords = report.keywords.map(k => normalizeText(k));

      return title.includes(normalized) ||
             abstract.includes(normalized) ||
             keywords.some(k => k.includes(normalized));
    });

    if (results.length === 0) {
      resultLabel.textContent = `"${query}" 검색 결과 0건`;
      resultsList.innerHTML = '<div class="no-results"><p>검색 결과가 없습니다.</p></div>';
      grid.style.display = 'none';
      resultsContainer.style.display = 'block';
      return;
    }

    resultLabel.textContent = `"${query}" 검색 결과 ${results.length}건`;
    const resultHTML = results.map(report => {
      const inst = institutionsData.find(i => i.code === report.institution);
      const instName = inst ? inst.name : '미분류';
      const isExternal = externalInsts.includes(report.institution);
      const href = isExternal ? report.source_url : report.url;
      const attrs = isExternal ? ' target="_blank" rel="noopener"' : '';
      return `
        <div class="search-result-item">
          <a href="${href}"${attrs}>
            <span class="search-result-inst">${instName}</span>
            <span class="search-result-title">${report.title}</span>
            <span class="search-result-date">${report.date}</span>
          </a>
        </div>
      `;
    }).join('');

    resultsList.innerHTML = resultHTML;
    grid.style.display = 'none';
    resultsContainer.style.display = 'block';
  }

  searchInput.addEventListener('input', (e) => {
    performSearch(e.target.value);
  });

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.value = '';
      performSearch('');
    }
  });
});
</script>
